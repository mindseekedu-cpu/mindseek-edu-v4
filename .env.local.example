# ============================================================
# SALIN file ini menjadi .env.local dan isi nilainya.
# JANGAN commit file .env.local ke repository Git.
# ============================================================

# ------------------------------------------------------------
# Supabase
# Dapatkan dari: https://app.supabase.com -> Project Settings -> API
# ------------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# ------------------------------------------------------------
# JSON Web Token
# Gunakan string acak yang panjang dan kompleks (min. 32 karakter)
# Contoh generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ------------------------------------------------------------
JWT_SECRET=your-very-strong-jwt-secret-key

# ------------------------------------------------------------
# DeepSeek AI API
# Dapatkan dari: https://platform.deepseek.com/api_keys
# ------------------------------------------------------------
DEEPSEEK_API_KEY=your-deepseek-api-key

# ------------------------------------------------------------
# OCR.space API
# Dapatkan dari: https://ocr.space/ocrapi (free tier tersedia)
# ------------------------------------------------------------
OCR_SPACE_API_KEY=your-ocr-space-api-key

# ------------------------------------------------------------
# Midtrans Payment Gateway
# Dapatkan dari: https://dashboard.midtrans.com -> Settings -> Access Keys
# Gunakan Sandbox key untuk development, Production key untuk live
# ------------------------------------------------------------
MIDTRANS_SERVER_KEY=your-midtrans-server-key

# ------------------------------------------------------------
# SendGrid Email Service
# Dapatkan dari: https://app.sendgrid.com/settings/api_keys
# ------------------------------------------------------------
SENDGRID_API_KEY=your-sendgrid-api-key

# ------------------------------------------------------------
# URL Aplikasi
# Development: http://localhost:3000
# Production: https://your-domain.com
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
